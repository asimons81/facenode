{
  "name": "@facenode/web-avatar",
  "version": "0.2.0",
  "description": "Three.js avatar renderer — procedural and glTF mesh, state animations, lip sync (amplitude + viseme)",
  "license": "MIT",
  "homepage": "https://github.com/asimons81/facenode",
  "repository": { "type": "git", "url": "https://github.com/asimons81/facenode.git", "directory": "apps/web-avatar" },
  "keywords": ["facenode", "avatar", "three.js", "gltf", "lip-sync", "tts"],
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@facenode/avatar-core": "workspace:*",
    "@facenode/avatar-sdk": "workspace:*",
    "@facenode/hermes-adapter": "workspace:*",
    "@facenode/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.164.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.164.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
