{
  "name": "@facenode/avatar-sdk",
  "version": "0.2.0",
  "description": "Minimal adapter interface for connecting any agent system to FaceNode",
  "license": "MIT",
  "homepage": "https://github.com/asimons81/facenode",
  "repository": { "type": "git", "url": "https://github.com/asimons81/facenode.git", "directory": "packages/avatar-sdk" },
  "keywords": ["facenode", "avatar", "ai-agent", "adapter", "sdk"],
  "type": "module",
